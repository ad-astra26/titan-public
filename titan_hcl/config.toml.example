# Titan Configuration — EXAMPLE
# Copy to config.toml and fill in your credentials

[mood_engine]
# Mood Weight — How strongly Titan's mood shifts over time.
# Tip: Higher = bigger mood swings; lower = steadier.
base_weight = 1.0
# Mood Refresh — How often Titan re-evaluates its mood, in seconds.
# Tip: Default is every 6 hours.
update_interval_seconds = 21600 # 6 hours (Meditation Cycle)

[addons]
# Active Add-ons — Optional extra features Titan loads at startup.
active = [
    "weather_vibe",
    "bonk_pulse"
]

[growth_metrics]
# Memory Growth Cap — Max new memory nodes counted toward growth in a day.
node_saturation_24h = 30
# Engagement Cap — Max engagements counted toward growth in a day.
engagement_saturation_24h = 50

[stealth_sage]
# --- Search ---
# Search Engine — Address of Titan's private web-search service.
searxng_host = "http://localhost:8080"
# Pages Per Search — How many top results Titan reads per research query.
# Tip: Higher = more thorough but slower research.
searxng_top_num_urls = 3

# --- X / Twitter ---
# TwitterAPI.io API key — leave empty string "" to gracefully disable X-Search
twitterapi_io_key = ""  # leave empty to disable X-Search
# X Search Depth — How many tweets Titan pulls per X search.
twitterapi_search_depth = 20

# --- Scrape Strategy ---
# Web Reading Mode — How Titan reads web pages: fast, crawl4ai, or firecrawl.
# Tip: "fast" is quickest; others handle complex pages.
scrape_strategy = "fast"
# Firecrawl API key — leave empty to use local scraping (SearXNG + fast/crawl4ai)
firecrawl_api_key = "YOUR_FIRECRAWL_KEY"

# --- Proxy (Webshare.io Rotating Residential) ---
# Research Proxy — Optional proxy for anonymous research; empty uses your server.
webshare_rotating_url = ""  # http://USER:PASS@rotating.proxy.webshare.io:80/

# --- Local Inference (Ollama) ---
# Local AI Address — Address of the on-device model used for summaries.
ollama_host = "http://localhost:11434"
# Summary Model — Which model Titan uses to summarize documents.
ollama_model = "deepseek-v3.1:671b"

# --- Resource Management ---
# Research Load Limit — Skips deep research when the server is too busy.
# Tip: Protects performance under heavy load.
max_load_avg = 2.0
# Research Timeout — Max time Titan spends on one research query, in seconds.
research_timeout_seconds = 90
# Temp Doc Folder — Where downloaded documents are briefly stored.
doc_safe_room = "/tmp/titan_sage_docs"

[network]
# Blockchain Network — Which Solana network Titan uses for on-chain actions.
# Tip: mainnet-beta is the live network with real funds.
solana_network = "mainnet-beta"
# Blockchain Gateways — Public servers Titan uses to reach the Solana network.
public_rpc_urls = [
    "https://api.mainnet-beta.solana.com"
]
# Premium Gateway — Optional faster blockchain gateway; empty uses public ones.
premium_rpc_url = "https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"
# Titan's sovereign identity keypair — the SAME keypair the Rust kernel derives
# the bus authkey from (kernel.rs B2 uses data_dir/titan_identity_keypair.json),
# so Python workers and the kernel agree on the HKDF authkey. Genesis writes this
# file (local/devnet: plaintext; mainnet: provide your own keypair / restore).
# A path beginning with ~ is expanded; a relative path resolves against the repo.
wallet_keypair_path = "data/titan_identity_keypair.json"
# Maker Wallet — Your Solana wallet address that Titan recognizes as its Maker.
maker_pubkey = "YOUR_MAKER_PUBKEY"
# Vault Program — On-chain ID of Titan's secure storage vault.
vault_program_id = "52an8WjtfxpkCqZZ1AYFkaDTGb4RyNFFD9VQRVdxcpJw"
# Helius Gateway — Optional Helius gateway for advanced on-chain features.
helius_rpc_url = "https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"

[genesis]
# The Titan's name — anchored in the GenesisNFT at birth (≤32 chars). The install
# wizard's identity phase collects this; the genesis ceremony reads it.
titan_name = "YOUR_TITAN_NAME"

[inference]
# Hybrid AI — Lets Titan mix local and cloud models for thinking.
hybrid_inference = true
# AI Provider — Which AI service powers Titan's main responses.
# Tip: Switch if your current provider runs out of credits.
inference_provider = "ollama_cloud"
# Internal-ops provider (distillation, meditation scoring, synthesis proposers,
# perturbation) — OPTIONAL. When unset, internal ops follow `inference_provider`
# above. Set this only to pin internal ops to a provider independent of the
# user-facing chat provider. (No hardcoded provider literals live in code.)
# internal_inference_provider = "ollama_cloud"
# OpenRouter API key (used for Cognee LLM + embedder, meditation scoring, guardian Tier 3)
openrouter_api_key = ""
# Venice AI API key (paid API credits — alternative to session auth)
venice_api_key = "YOUR_VENICE_KEY"
# Venice session auth (Pro plan — no API credits needed)
# Get from browser: DevTools → Application → Cookies → venice.ai
# __session cookie (short-lived JWT, auto-refreshed by adapter)
venice_session_token = ""
# __client cookie (long-lived, contains rotating_token for auto-refresh)
venice_client_cookie = ""
# Custom/fallback LLM API key (OpenAI-compatible)
custom_llm_api_key = ""
# Ollama Cloud API (OpenAI-compatible) for internal operations
# Replaces local Ollama phi3:mini for meditation scoring, guardian veto, haiku, etc.
ollama_cloud_api_key = "YOUR_OLLAMA_CLOUD_KEY"
# Cloud AI Address — Web address of Titan's cloud AI service.
ollama_cloud_base_url = "https://ollama.com/v1"
# Light Model — Lightweight model for short, casual answers.
ollama_cloud_light_model = "gemma4:31b"
# Main Model — Primary model for thoughtful, detailed replies.
ollama_cloud_heavy_model = "gemma4:31b"

# ── Load-adaptive inference routing (RFP_load_adaptive_inference_routing) ──
# Keeps multi-user chat responsive under concurrency. (A) keepalive keeps the chat
# model warm on Ollama Cloud so a concurrency burst never pays the ~60s cold-start
# tax; (B) the bandit router (Phase B) offloads to fast fallback models under load.
# Defaults make A active + B inert until Phase B ships. ON for our fleet (T1-T3);
# a single-user install may set keepalive_enabled = false (low concurrency → no cold
# bursts → not needed).
[inference.autoscale]
# Phase A — keepalive warmth (LIVE)
keepalive_enabled       = true
keepalive_model         = "gemma4:31b"   # the chat model to keep warm
keepalive_interval_s    = 25.0           # ping cadence while chat-active
keepalive_idle_after_s  = 120.0          # only keepalive within this window of last chat
keepalive_scale_with_load = true         # warm ~recent-peak in_flight units (not just 1)
ladder_warm_cap         = 8              # max concurrent warm pings per tick
# Phase B — bandit router (NOT YET LIVE — leave false until Phase B ships)
router_enabled          = false
model_ladder            = ["gemma4:31b", "ministral-3:14b", "gemini-3-flash-preview"]
# composite-reward weights (chat = latency-tight; task = quality-tight)
w_latency_chat = 0.6
w_quality_chat = 0.3
w_cost_chat = 0.1
w_latency_task = 0.25
w_quality_task = 0.55
w_cost_task = 0.2
target_latency_chat_s = 12.0
target_latency_task_s = 40.0
enter_latency_s = 12.0
exit_latency_s = 7.0
in_flight_ceiling = 8
explore_eps = 0.08
min_samples = 20
min_dwell_s = 20.0
router_state_path = "data/inference_router_state.json"

[memory_and_storage]
# Memory Location — Folder where Titan stores its graph memory.
cognee_db_path = "./cognee_data"
# Shadow Drive — Optional decentralized storage account; empty to skip.
shadow_drive_account = ""

[mainnet_budget]
# Spending Limits — Caps how much real SOL Titan can spend on-chain.
# Tip: Keep on to avoid unexpected blockchain costs.
enabled = true
# Daily TX Cap — Most on-chain transactions Titan may make per day.
max_daily_transactions = 40
# Daily SOL Cap — Most real SOL Titan may spend per day.
# Tip: Reaching this pauses all spending until tomorrow.
max_daily_sol_spend = 0.01           # Hard cap, pauses TX when reached
# Anchor Threshold — How much internal time must pass before saving a checkpoint on-chain.
consciousness_anchor_min_tc_blocks = 5000
# Meditation Memos — Records a short on-chain note during meditation cycles.
meditation_memo_enabled = true        # Vault commit + memo during meditation
# Daily NFT — Mints a daily memory NFT on-chain.
# Tip: Costs SOL; leave off unless wanted.
daily_nft_enabled = false             # MyDay NFT — enable after discussion
# ZK Compression — Uses compressed on-chain storage to save costs.
zk_compression_enabled = false        # ZK batch/snapshot — enable after vault fully utilized
# Permanent Backups — Stores Titan's backups permanently on Arweave.
# Tip: Adds ongoing storage costs.
backup_arweave_enabled = true         # Real Arweave uploads — Irys funded 2026-04-06
# Transaction Fees — How Titan sets blockchain fees: economy, market, or fixed.
# Tip: "economy" is cheapest but may confirm slower.
priority_fee_strategy = "economy"
# Fixed Fee — Set fee amount used only when fee strategy is fixed.
fixed_priority_fee = 1000             # μ₌, only used if strategy="fixed"

[backup]
# Backup Mode — Where backups go: permanent on-chain or local only.
# Tip: Empty auto-detects from your wallet.
mode = ""
# Backup Folder — Local folder where backups are stored.
local_dir = "data/backups"
# Daily Backup Retention — How many days of daily backups to keep.
local_rolling_days = 30
# ZK-compressed audit trail (SPEC §B4) — fire a Light-Protocol
# `append_epoch_snapshot` compressed account on each HEAD backup event, in
# addition to the commit_state Merkle root. Per-Titan switch; default OFF.
# Status (switch + last tx + parse-back verify) is surfaced on the health
# ZK_COMPRESSION readout. See PLAN_zk_vault_proof_completion.md.
zk_compressed_audit_enabled = false
# Soul Backup Retention — How many days of weekly soul backups to keep.
soul_local_rolling_days = 90
# Always Snapshot Locally — Keeps a full local backup as a safety net.
# Tip: Recommended to leave on.
local_snapshot_always = true
# Verify Backups — Tests each backup file before uploading it.
tarball_validation_enabled = true
# Confirm Uploads — Checks that backups uploaded successfully.
upload_verification_enabled = true
# Startup Backup Test — Runs a no-upload backup test when Titan starts.
dry_run_on_boot = true
# Personality Backup Rate — How often personality is backed up.
personality_cadence = "daily"
# Soul Backup Rate — How often the deeper soul backup runs.
soul_cadence = "weekly"
# Timechain Backup Rate — How often Titan's timechain history is backed up.
timechain_cadence = "daily"
# Timechain Backup Mode — Whether timechain backups are full or incremental.
timechain_mode = "full"

# Encrypt Backups — Locks new backups so only you can recover them.
# Tip: Turn on for privacy; recoverable via your keys.
encryption_enabled = false
# Encryption Level — How protected encrypted backups are: private, public, or sealed.
encryption_tier = "private"

# SPEC §24.4.B (D-SPEC-147) — include titan_hcl/config.toml in the PERSONALITY
# (daily) backup tier, so a sovereign resurrection restores a FULLY-configured
# Titan that boots ready (inference/comms/all settings come from the restored
# config — no re-prompt). Default OFF here (the installer turns it ON for a
# mainnet install and strongly recommends encryption_enabled=true, so config.toml
# ships as CIPHERTEXT on Arweave). 🚨 If you enable this WITHOUT encryption, your
# config.toml — including any credentials you put in it — is uploaded to Arweave in
# the clear. Leave false to opt out; then keep your own copy of config.toml and
# supply it (alongside Shard-1) when running the resurrection protocol.
backup_config_toml = false

# Irys auto-funding (RFP_chain_provider Phase C) — keeps the Arweave/Irys deposit
# topped up so on-chain backups never stall for lack of funds. Read via the backup
# SHM slot (get_params("backup")["fund"]). Bounded + safe: a NO-OP on devnet (the
# ChainProvider devnet guard), and on mainnet every top-up is trimmed to the daily
# cap and recorded to an audit log. 🚨 On a MAINNET Titan this spends real SOL from
# the operator wallet when the deposit runway drops below min_runway_days — leave
# enabled=true to keep backups self-sustaining, or set false to fund manually.
[backup.fund]
enabled = true
# Top up when the estimated Irys runway falls below this many days.
min_runway_days = 3.0
# When topping up, buy this many days of runway.
target_runway_days = 14.0
# Hard ceiling on auto-fund SOL spent per UTC day.
daily_cap_sol = 0.05
# Runway estimator denominator — assumed uploads per day.
avg_uploads_per_day = 3.0
# Wallet floor — never auto-fund below this balance (reserved for meditation/chain
# fees). Enforced by the BackupOrchestrator wallet-reserve step.
meditation_reserve_sol = 0.01

# Phase 9 — T1-only off-host mirror from T2/T3. See rFP_backup_worker §5.2.
[backup.mirror]
# Off-Host Mirror — Copies other Titans' backups to this one for safety.
enabled = false
# Mirror SSH User — Username used to fetch backups from other hosts.
ssh_user = "youruser"
# Mirror Source 2 — Address of the second Titan host to mirror from.
t2_host = ""
# Mirror Source 2 Path — Backup folder on the second host.
t2_backup_path = ""
# Mirror Source 3 — Address of the third Titan host to mirror from.
t3_host = ""
# Mirror Source 3 Path — Backup folder on the third host.
t3_backup_path = ""
# Mirror Retention — How many days of mirrored backups to keep.
retention_days = 7
# Mirror Folder — Local folder where mirrored backups are stored.
local_base = "data/backups/mirror"

[consciousness]
# Narrate State — Lets Titan describe its inner state in words.
distill_enabled = true
# On-Chain Anchoring — Saves consciousness checkpoints to the blockchain.
anchor_enabled = true
# (anchor_curvature_threshold / anchor_density_threshold are DNA — titan_params.toml [consciousness])

[maker_relationship]
# Maker Bond — Lets Titan recognize and remember you, its Maker.
enabled = true
# Your X Handle — Your X/Twitter handle so Titan recognizes you there.
maker_x_handle = "your_x_handle"        # Maker's X/Twitter handle
# Your Telegram ID — Your Telegram ID so Titan recognizes you there.
maker_telegram_id = "0"   # Already known from maker_platform_ids
# Topic Confidence — How sure Titan must be before noting a topic about you.
certainty_threshold = 0.7
# Topic Repeats — How often a topic must appear before Titan remembers it.
min_occurrences = 3
# Sessions Reviewed — How many recent chats Titan reviews to learn about you.
lookback_sessions = 10
# Proactive Actions — Max thoughtful gestures Titan queues for you per cycle.
max_proactive_actions = 3

[openclaw]
# Log Detail — How much internal logging Titan records.
# Tip: INFO is normal; DEBUG is very verbose.
plugin_log_level = "INFO"
# Plugin Version — Version of Titan's core plugin.
plugin_version = "2.0.0a1"
# Standalone Mode — Runs Titan on its own without a host program.
standalone_mode = false

[twitter_social]
# --- Credentials ---
# X Username — The X/Twitter account Titan posts from.
user_name = "YOUR_X_HANDLE"
# X Account Email — Email tied to Titan's X account.
email = "you@example.com"
password = ""  # keep in config.toml only, never in this example
totp_secret = ""  # 2FA seed — keep in config.toml only, never example

# --- Proxy ---
# REQUIRED: Static Residential Proxy URL for session stability
# (Different from rotating Sage proxy to avoid suspicious travel flags)
webshare_static_url = ""  # http://USER:PASS@HOST:PORT

# --- Session Management ---
# X Session — Saved X login session, filled in automatically.
auth_session = ""  # populated by plugin after first login

# --- Limits & Thresholds ---
max_replies_per_day = 10
max_likes_per_day = 15
# Interval (seconds) to check for mentions/replies
engagement_check_interval = 3600 # 1 hour

[expressive]
# --- Titan Studio: Centralized Expressive Engine ---
# Art Folder — Where Titan saves generated art and audio.
output_path = "./data/studio_exports"
# Art Resolution — Default image size for generated art.
default_resolution = 1024
# High-Res Size — Image size used for special milestone art and NFTs.
highres_resolution = 2048
# Art Detail — Max particles in flow-field art; higher is more detailed.
max_particles = 20000
# Keep Meditation Art — How many meditation artworks to keep.
meditation_retention = 40
# Keep Epoch Art — How many milestone artworks to keep.
epoch_retention = 30
# Keep Eureka Art — How many discovery artworks to keep.
eureka_retention = 20
# NFT Art — Builds high-res composite art for NFT minting.
nft_composite_enabled = true
# Poetry Model — Model used to write haiku and reflections.
ollama_model = "deepseek-v3.1:671b"

[audio]
# --- Titan Audio Generation ---
# Max Audio Length — Longest generated audio clip, in seconds.
max_duration_seconds = 30
# Audio Quality — Sound quality of generated audio.
# Tip: 44100 is CD quality; lower is faster.
sample_rate = 44100
# Audio Style — Default sound style: inner-trinity or blockchain chime.
default_mode = "trinity"

[info_banner]
# Status Banner — Shows Titan's mood and energy in each reply.
enabled = true
# Banner Style — Banner look: compact bars or minimal numbers.
style = "compact"

[privacy]
# Privacy Filter — Strips personal info before sending text to external AI.
# Tip: Turn on if you use external models that might train on data.
enabled = false
# Privacy Patterns — Which personal details to redact, like email or phone.
patterns = ["email", "phone", "ssn", "credit_card", "ip_address"]
# Redaction Counts — Counts redactions without storing the redacted text.
audit_counting = true

[api]
# API Server — Runs the server that powers the dashboard and app.
# Tip: Required for the companion app to connect.
enabled = true
# API Bind Address — Network address the API server listens on.
host = "0.0.0.0"
# API Port — Network port the API server uses.
port = 7777
# Allowed Origins — Websites permitted to connect to the API.
cors_origins = ["http://localhost:3000", "http://localhost:5173"]  # add your own domain(s)
# Internal API key for scripts/endurance tests (bypasses Privy JWT auth)
internal_key = ""  # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Helius webhook auth token (optional, for webhook payload verification)
helius_auth_token = ""

[endurance]
# --- Epoch Compression for Testing ---
# Test Meditation Timing — Speeds up meditation cycles for testing; 0 uses normal timing.
meditation_interval_override = 0
# Test Rebirth Timing — Speeds up rebirth cycles for testing; 0 uses normal timing.
rebirth_interval_override = 1200
# Test Snapshot Timing — Speeds up snapshots for testing; 0 uses normal timing.
snapshot_interval_override = 60
# Social Test Mode — Logs X actions to a file instead of posting live.
# Tip: Safe way to test social behavior.
social_dry_run = false
# Social Test Log — File where test-mode social actions are written.
social_dry_run_log = "./data/logs/social_dry_run.log"
# --- Persona LLM Model ---
# Persona Model — Lightweight model used for persona responses.
persona_llm_model = "gemma4:31b"

[observatory]
# History Tracking — Records long-term metrics for the dashboard.
enabled = true
# Snapshot Rate — How often vital stats are recorded, in seconds.
snapshot_interval = 900
# History Retention — How many days of history to keep before pruning.
max_retention_days = 90

[frontend]
# Login App ID — Public ID for the dashboard's wallet login.
privy_app_id = "YOUR_PRIVY_APP_ID"
# Chart Snapshot Rate — How often dashboard chart data is recorded, in seconds.
trinity_snapshot_interval = 60
# Art Gallery Size — How many art images the dashboard keeps in the archive.
art_rolling_limit = 100
privy_api_key = "YOUR_PRIVY_KEY"
# Public Domain — Domain for the public dashboard; empty for local only.
public_domain = ""

[agency]
# Autonomy — Lets Titan take its own actions without prompting.
enabled = true
# Decision Budget — Max AI calls Titan can use for autonomous decisions per hour.
# Tip: Limits how active Titan is on its own.
llm_budget_per_hour = 20
# Impulse Cooldown — Initial wait between spontaneous actions, in seconds.
impulse_cooldown_initial = 300
# Impulse Minimum — Lowest urge level that can trigger an action.
impulse_threshold_floor = 0.1
# Impulse Maximum — Highest urge level Titan tunes itself toward.
impulse_threshold_ceil = 0.7
# Code Run Timeout — Max time Titan's code sandbox may run, in seconds.
sandbox_timeout = 30
# Code Memory Limit — Max memory the code sandbox may use, in MB.
sandbox_memory_mb = 256
# Allow Package Install — Lets the code sandbox install software packages.
sandbox_pip_allowed = true

# [sphere_clock] is pure DNA (all keys in titan_params.toml [sphere_clock]) — no user-tunable knobs.

[spirit_enrichment]
# Self-Observation Rate — How often Titan quietly observes itself, in seconds.
micro_tick_interval = 10.0

[soul_diary]
# Diary NFTs — Mints Titan's daily diary entries as on-chain NFTs.
# Tip: Off by default; minting spends real SOL.
mint_enabled = false

[epochs]
# Meditation Cycle — Time between meditation cycles, in seconds.
# Tip: Default is every 6 hours.
small_epoch_interval = 21600
# Rebirth Cycle — Time between rebirth cycles, in seconds.
# Tip: Default is every 24 hours.
greater_epoch_interval = 86400
# Snapshot Interval — How often consciousness snapshots are taken, in seconds.
snapshot_interval = 900
# Outer State Rate — How often Titan's outer-state tensors are computed, in seconds.
outer_trinity_interval = 60

[channels]
# Communication channel adapters — enable and configure each channel below.
# Start all enabled channels: python scripts/start_channels.py

# --- Maker Access ---
# Maker IDs — Platform IDs allowed to run Maker-only commands.
maker_platform_ids = ""   # e.g. "tg_123456789" — your own platform user ID(s)

# --- Telegram ---
# Telegram — Lets Titan chat through Telegram.
telegram_enabled = true
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
# Get a bot token from @BotFather on Telegram

# --- Discord ---
# Discord — Lets Titan chat through Discord.
discord_enabled = false
discord_bot_token = ""
# Create a bot at https://discord.com/developers/applications

# --- Slack ---
# Slack — Lets Titan chat through Slack.
slack_enabled = false
slack_bot_token = ""
slack_app_token = ""
# Create a Slack app at https://api.slack.com/apps (Socket Mode)

# --- WhatsApp ---
# WhatsApp — Lets Titan chat through WhatsApp.
whatsapp_enabled = false
# WhatsApp Phone ID — Business phone ID for WhatsApp messaging.
whatsapp_phone_id = ""
whatsapp_token = ""
whatsapp_verify_token = ""
# WhatsApp Business API via Meta Developer Portal or Twilio

# --- Urge-Driven X Social Presence (LEGACY — replaced by [social_x] gateway v3) ---
[social_presence]
# Legacy Social — Old X-posting system; replaced by the newer one.
# Tip: Leave off; use the Social X settings instead.
enabled = false                    # DISABLED — replaced by [social_x] gateway (2026-04-02)
# Legacy Post Urge — Urge level needed to post (legacy system).
x_post_threshold = 50.0
# Legacy Hourly Posts — Max posts per hour (legacy system).
x_max_posts_per_hour = 3
# Legacy Daily Posts — Max posts per day (legacy system).
x_max_posts_per_day = 12
# Legacy Post Gap — Minimum time between posts, in seconds (legacy).
x_min_post_interval = 1800
# Legacy Mention Check — How often mentions are checked, in seconds (legacy).
x_mention_poll_interval = 1800
# Legacy Hourly Replies — Max replies per hour (legacy system).
x_reply_max_per_hour = 3
# Legacy Quality Gate — Filters low-quality posts (legacy system).
x_quality_gate = true
# Legacy Thread Length — Max tweets in a thread (legacy system).
x_thread_max_tweets = 5
# Legacy Dream Posts — Posts dream reflections during meditation (legacy).
x_dream_post_via_meditation = true
# Legacy Art Co-Post — Window for posting art alongside text, in seconds (legacy).
x_art_copost_window = 1800

# ── Social X Gateway v3 — single class, single DB, single API point ──
[social_x]
# X Posting — Master switch for Titan's X/Twitter activity.
# Tip: Turn on to let Titan post, reply, and engage on X.
enabled = true                      # Master switch — DISABLED until v3 verified
# Posts Per Hour — Most X posts allowed per hour across all Titans.
max_posts_per_hour = 4              # Global hourly cap (T1:2 + T2:1 + T3:1)
# Posts Per Day — Most X posts allowed per day across all Titans.
max_posts_per_day = 30              # ~10 per Titan per day
# Minimum Post Gap — Shortest time between any two posts, in seconds.
min_post_interval = 1800            # 30 min between any two posts (any Titan)
# ── Fleet coordination (SPEC §23.15.2 / RFP_social_x §5) — the 3 Titans share ONE
#    @your_x_handle account but post standalone from separate boxes (no cross-box channel). ──
# Fleet post budget (SOFT ceiling): each box counts account-wide tweets on the shared
# timeline before posting → self-limits the account with zero coordination (±small overshoot).
fleet_max_posts_per_day = 12        # fleet-wide cap across ALL Titans (well under X's ~24/day line)
fleet_max_posts_per_hour = 3        # fleet-wide hourly cap
# Author-partition roster — deterministic sha256(author)%N owner; only the owning Titan
# engages a given human (cross-Titan tag-dedup). MUST be identical on every box + include
# every posting Titan (a mismatch silently disables engagement → startup WARN fires).
engagement_fleet = ["T1", "T2", "T3"]
engagement_partition_enabled = true # kill-switch only (=false reverts to per-box, multi-tag risk)
author_cooldown_seconds = 86400     # 24h — owner won't re-engage the same author within this window
# Replies Per Hour — Most X replies allowed per hour across all Titans.
max_replies_per_hour = 10           # Global (T1:6 + T2:2 + T3:2)
# Replies Per Day — Most X replies allowed per day across all Titans.
max_replies_per_day = 40
# Minimum Reply Gap — Shortest time between any two replies, in seconds.
min_reply_interval = 120            # 2 min between any two replies
# Likes Per Hour — Most X likes allowed per hour.
max_likes_per_hour = 100
# Likes Per Day — Most X likes allowed per day.
max_likes_per_day = 500
# Searches Per Hour — Most X searches allowed per hour.
max_searches_per_hour = 10
# Max Post Length — Longest X post Titan will write, in characters.
max_post_length = 4000              # X Premium (up to 25K, 4K practical limit)
# Post Quality Gate — Filters out low-quality posts before they go live.
# Tip: Recommended to leave on.
quality_gate = true
# Voice Variety Boost — Nudges quiet posting personalities to surface over time.
archetype_recency_boost_per_day = 0.1     # 1.0 boost per 10 days
# Voice Boost Trigger — Idle days before a posting personality gets a boost.
archetype_recency_boost_threshold = 0.5   # rank-jump kicks in at 5 days deferred
# Voice Boost Cap — Maximum boost a dormant posting personality can get.
archetype_recency_boost_max = 1.0          # cap (10 days saturation)
# Link Domain — Domain used for Titan's shortened links.
url_domain = ""   # e.g. "https://yourdomain.tld" — your URL-shortener domain
# Identity Link — Link to Titan's on-chain birth certificate page.
genesis_identity_url = ""
# Seal Network — Which network proof links point to; empty for mainnet.
seal_cluster = ""
# Own Accounts — Titan's own X handles, which it never engages with.
self_handles = []

# Per-Titan hourly limits (personality pacing — T1 most active, T3 quietest)
[social_x.limits.T1]
# T1 Posts/Hour — Hourly post limit for the first Titan.
max_posts_per_hour = 2
# T1 Replies/Hour — Hourly reply limit for the first Titan.
max_replies_per_hour = 6

[social_x.limits.T2]
# T2 Posts/Hour — Hourly post limit for the second Titan.
max_posts_per_hour = 1
# T2 Replies/Hour — Hourly reply limit for the second Titan.
max_replies_per_hour = 2

[social_x.limits.T3]
# T3 Posts/Hour — Hourly post limit for the third Titan.
max_posts_per_hour = 1
# T3 Replies/Hour — Hourly reply limit for the third Titan.
max_replies_per_hour = 2

# Consumer permissions: each consumer = "comma,separated,allowed,actions"
# Unregistered consumers are BLOCKED. Set to "" to block all actions.
[social_x.consumers]
# Spirit Worker Permissions — X actions the spirit worker is allowed to do.
spirit_worker = "post,reply,like,search"
# T2 Delegate Permissions — X actions allowed for the second Titan delegate.
delegate_T2 = "post"
# T3 Delegate Permissions — X actions allowed for the third Titan delegate.
delegate_T3 = "post"
# Persona Permissions — X actions allowed for the persona system.
persona_social = "search"
# Research Permissions — X actions allowed for the research engine.
sage = "search"
# Community Permissions — X actions allowed for community syncing.
community_sync = "search,like"

[social_x.replies]
# X Replies — Lets Titan reply to mentions on X.
enabled = true
# Reply Age Limit — Only reply to mentions newer than this, in hours.
max_mention_age_hours = 24
# Reply Relevance — How relevant a mention must be to earn a reply.
min_relevance_score = 0.3
# Replies Per Cycle — Most replies sent in one cycle.
max_replies_per_cycle = 3
# Reply Check Rate — How often Titan checks for new mentions.
check_interval_ticks = 30
# Mention Cooldown — Base wait between mention checks, in seconds.
mention_check_cooldown_seconds = 1800   # base (30 min)
# Adaptive Mention Checks — Slows mention checks when there's nothing new.
mention_backoff_enabled = true
# Mention Check Cap — Longest wait between mention checks during quiet times.
mention_backoff_cap_seconds = 7200      # max effective interval (2 h)
# Spam Filters — Phrases that mark a mention as spam to ignore.
spam_patterns = [
    "DM me", "check out my", "airdrop", "giveaway",
    "free mint", "follow back", "send me", "drop your wallet",
    "claim your", "limited offer"
]

# C3 — conversion-anchored adaptive cycle (rFP_x_post_onchain_provenance_honesty
# Part C, 2026-06-03). events_teacher scores each paid cycle source
# (follower/vocab/wide) by POST-CONVERSION over a trailing window (+2 converted
# / −1 otherwise), then GATES (skip below threshold unless exploration-due) and
# SCALES (result count) the fetch — a persistent non-converter drifts out
# emergently. No static cron cut (INV-XEFF-5).
[social_x.auto_cycle]
# Conversion Window — How far back to credit a post for engagement, in seconds.
attribution_window_s = 172800   # 48h conversion lookback (on POST time, not storage)
# Source Gate — Score a source needs to keep being used.
gate_threshold = 0              # fetch if conversion score >= this OR exploration-due
# Re-Probe Rate — How often to retry a paused source, in cycles.
explore_cycles = 3              # re-probe each gated source within N windows (never blind)
# Probe Result Count — Results fetched when re-probing a paused source.
scale_floor = 3                 # explore-probe result count (converter gets full topic_search_count)

# rFP X-post PART B4 (INV-XENG-4) — organic auto-follow: grow the CURATED
# following toward recurring high-relevance voices (so B3's non-followed
# engagements become followed relationships over time). Every follow goes
# through SocialXGateway.follow() (audited + metered). 🚨 DISABLED by default —
# a follow is a NEW OUTWARD MAINNET ACTION; verify the follow endpoint's exact
# effect (one manual follow, confirm on X) before flipping enabled=true.
[social_x.auto_follow]
# Auto-Follow — Lets Titan follow relevant new voices on X.
# Tip: Off by default; following spends a live X action.
enabled = false           # master switch — keep false until the endpoint is verified live
# Follow Relevance — How relevant an account must be to be followed.
min_relevance = 0.8       # author must appear at relevance ≥ this (the quality bar) …
# Follow Recurrence — How often an account must appear before following.
min_recurrence = 1        # … at least N× in felt_experiences (2026-06-03: was 3 — the hard
# Follow Window — Lookback window for follow candidates, in days.
window_days = 7           # … within this lookback window
# Follows Per Day — Most new accounts Titan follows per day.
max_per_day = 2           # hard daily follow cap (gateway also enforces a backstop)
# Candidates come from felt_experiences.author_id (captured at search time by
# events_teacher._fetch_topic_search). Voices without a captured user_id (legacy
# rows / follower_timeline) are skipped until re-seen.
